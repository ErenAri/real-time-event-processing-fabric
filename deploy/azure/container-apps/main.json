{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "14582350541214243132"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "pulsestream",
      "metadata": {
        "description": "Shared prefix used for Azure resource names."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "[format('{0}-logs', parameters('namePrefix'))]",
      "metadata": {
        "description": "Log Analytics workspace name."
      }
    },
    "containerAppsEnvironmentName": {
      "type": "string",
      "defaultValue": "[format('{0}-env', parameters('namePrefix'))]",
      "metadata": {
        "description": "Container Apps environment name."
      }
    },
    "ingestAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-ingest', parameters('namePrefix'))]",
      "metadata": {
        "description": "Container app name for the ingest service."
      }
    },
    "queryAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-query', parameters('namePrefix'))]",
      "metadata": {
        "description": "Container app name for the query service."
      }
    },
    "processorAppName": {
      "type": "string",
      "defaultValue": "[format('{0}-processor', parameters('namePrefix'))]",
      "metadata": {
        "description": "Container app name for the stream processor."
      }
    },
    "ingestImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the ingest service."
      }
    },
    "queryImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the query service."
      }
    },
    "processorImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the stream processor."
      }
    },
    "postgresAppUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Application connection string that services use for PostgreSQL runtime access."
      }
    },
    "postgresAdminUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Administrative PostgreSQL connection string used for schema bootstrap and role setup."
      }
    },
    "eventHubsHost": {
      "type": "string",
      "metadata": {
        "description": "Event Hubs namespace host name without a port, for example mynamespace.servicebus.windows.net."
      }
    },
    "eventHubsConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Event Hubs namespace connection string used with the Kafka endpoint and SASL/PLAIN."
      }
    },
    "kafkaTopic": {
      "type": "string",
      "defaultValue": "pulsestream.events",
      "metadata": {
        "description": "Kafka topic or Event Hub name for accepted telemetry."
      }
    },
    "kafkaDlqTopic": {
      "type": "string",
      "defaultValue": "pulsestream.events.dlq",
      "metadata": {
        "description": "Kafka topic or Event Hub name for processor dead letters."
      }
    },
    "kafkaGroupId": {
      "type": "string",
      "defaultValue": "pulsestream-processor",
      "metadata": {
        "description": "Kafka consumer group used by stream-processor."
      }
    },
    "authJwtSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT signing secret for ingest and query services."
      }
    },
    "authJwtIssuer": {
      "type": "string",
      "defaultValue": "pulsestream-azure",
      "metadata": {
        "description": "JWT issuer for Azure deployments."
      }
    },
    "authJwtAudience": {
      "type": "string",
      "defaultValue": "pulsestream-azure",
      "metadata": {
        "description": "JWT audience for Azure deployments."
      }
    },
    "adminToken": {
      "type": "securestring",
      "metadata": {
        "description": "Admin token for replay and local break-glass operations."
      }
    },
    "blobArchiveAccountUrl": {
      "type": "string",
      "metadata": {
        "description": "Blob Storage account URL used for the raw archive, for example https://account.blob.core.windows.net/."
      }
    },
    "blobArchiveContainer": {
      "type": "string",
      "defaultValue": "raw-archive",
      "metadata": {
        "description": "Blob container used for archived raw events."
      }
    },
    "blobArchivePrefix": {
      "type": "string",
      "defaultValue": "raw-archive",
      "metadata": {
        "description": "Blob prefix used for archived raw events."
      }
    },
    "ingestMinReplicas": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Replica count floor for ingest-service."
      }
    },
    "ingestMaxReplicas": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Replica count ceiling for ingest-service."
      }
    },
    "queryMinReplicas": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Replica count floor for query-service."
      }
    },
    "queryMaxReplicas": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Replica count ceiling for query-service."
      }
    },
    "processorMinReplicas": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Replica count floor for stream-processor."
      }
    },
    "processorMaxReplicas": {
      "type": "int",
      "defaultValue": 3,
      "metadata": {
        "description": "Replica count ceiling for stream-processor."
      }
    },
    "ingestCpu": {
      "type": "string",
      "defaultValue": "0.5",
      "metadata": {
        "description": "CPU allocation for ingest-service."
      }
    },
    "ingestMemory": {
      "type": "string",
      "defaultValue": "1Gi",
      "metadata": {
        "description": "Memory allocation for ingest-service."
      }
    },
    "queryCpu": {
      "type": "string",
      "defaultValue": "0.5",
      "metadata": {
        "description": "CPU allocation for query-service."
      }
    },
    "queryMemory": {
      "type": "string",
      "defaultValue": "1Gi",
      "metadata": {
        "description": "Memory allocation for query-service."
      }
    },
    "processorCpu": {
      "type": "string",
      "defaultValue": "0.75",
      "metadata": {
        "description": "CPU allocation for stream-processor."
      }
    },
    "processorMemory": {
      "type": "string",
      "defaultValue": "1.5Gi",
      "metadata": {
        "description": "Memory allocation for stream-processor."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[parameters('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppsEnvironmentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('ingestAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto"
          },
          "secrets": [
            {
              "name": "postgres-app-url",
              "value": "[parameters('postgresAppUrl')]"
            },
            {
              "name": "postgres-admin-url",
              "value": "[parameters('postgresAdminUrl')]"
            },
            {
              "name": "eventhubs-connection-string",
              "value": "[parameters('eventHubsConnectionString')]"
            },
            {
              "name": "auth-jwt-secret",
              "value": "[parameters('authJwtSecret')]"
            },
            {
              "name": "admin-token",
              "value": "[parameters('adminToken')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "ingest-service",
              "image": "[parameters('ingestImage')]",
              "env": [
                {
                  "name": "INGEST_LISTEN_ADDR",
                  "value": ":8080"
                },
                {
                  "name": "POSTGRES_URL",
                  "secretRef": "postgres-app-url"
                },
                {
                  "name": "POSTGRES_ADMIN_URL",
                  "secretRef": "postgres-admin-url"
                },
                {
                  "name": "KAFKA_BROKERS",
                  "value": "[format('{0}:9093', parameters('eventHubsHost'))]"
                },
                {
                  "name": "KAFKA_TOPIC",
                  "value": "[parameters('kafkaTopic')]"
                },
                {
                  "name": "KAFKA_SECURITY_PROTOCOL",
                  "value": "SASL_SSL"
                },
                {
                  "name": "KAFKA_SASL_MECHANISM",
                  "value": "PLAIN"
                },
                {
                  "name": "KAFKA_SASL_USERNAME",
                  "value": "$ConnectionString"
                },
                {
                  "name": "KAFKA_SASL_PASSWORD",
                  "secretRef": "eventhubs-connection-string"
                },
                {
                  "name": "KAFKA_TLS_SERVER_NAME",
                  "value": "[parameters('eventHubsHost')]"
                },
                {
                  "name": "KAFKA_ALLOW_AUTO_TOPIC_CREATION",
                  "value": "false"
                },
                {
                  "name": "RAW_ARCHIVE_BACKEND",
                  "value": "azure_blob"
                },
                {
                  "name": "RAW_ARCHIVE_AZURE_BLOB_ACCOUNT_URL",
                  "value": "[parameters('blobArchiveAccountUrl')]"
                },
                {
                  "name": "RAW_ARCHIVE_AZURE_BLOB_CONTAINER",
                  "value": "[parameters('blobArchiveContainer')]"
                },
                {
                  "name": "RAW_ARCHIVE_AZURE_BLOB_PREFIX",
                  "value": "[parameters('blobArchivePrefix')]"
                },
                {
                  "name": "RAW_ARCHIVE_FLUSH_INTERVAL",
                  "value": "5s"
                },
                {
                  "name": "RAW_ARCHIVE_FLUSH_BYTES",
                  "value": "262144"
                },
                {
                  "name": "AUTH_JWT_SECRET",
                  "secretRef": "auth-jwt-secret"
                },
                {
                  "name": "AUTH_JWT_ISSUER",
                  "value": "[parameters('authJwtIssuer')]"
                },
                {
                  "name": "AUTH_JWT_AUDIENCE",
                  "value": "[parameters('authJwtAudience')]"
                },
                {
                  "name": "ADMIN_TOKEN",
                  "secretRef": "admin-token"
                }
              ],
              "resources": {
                "cpu": "[json(parameters('ingestCpu'))]",
                "memory": "[parameters('ingestMemory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('ingestMinReplicas')]",
            "maxReplicas": "[parameters('ingestMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('queryAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8081,
            "transport": "auto"
          },
          "secrets": [
            {
              "name": "postgres-app-url",
              "value": "[parameters('postgresAppUrl')]"
            },
            {
              "name": "postgres-admin-url",
              "value": "[parameters('postgresAdminUrl')]"
            },
            {
              "name": "auth-jwt-secret",
              "value": "[parameters('authJwtSecret')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "query-service",
              "image": "[parameters('queryImage')]",
              "env": [
                {
                  "name": "QUERY_LISTEN_ADDR",
                  "value": ":8081"
                },
                {
                  "name": "POSTGRES_URL",
                  "secretRef": "postgres-app-url"
                },
                {
                  "name": "POSTGRES_ADMIN_URL",
                  "secretRef": "postgres-admin-url"
                },
                {
                  "name": "AUTH_JWT_SECRET",
                  "secretRef": "auth-jwt-secret"
                },
                {
                  "name": "AUTH_JWT_ISSUER",
                  "value": "[parameters('authJwtIssuer')]"
                },
                {
                  "name": "AUTH_JWT_AUDIENCE",
                  "value": "[parameters('authJwtAudience')]"
                }
              ],
              "resources": {
                "cpu": "[json(parameters('queryCpu'))]",
                "memory": "[parameters('queryMemory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('queryMinReplicas')]",
            "maxReplicas": "[parameters('queryMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('processorAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "secrets": [
            {
              "name": "postgres-app-url",
              "value": "[parameters('postgresAppUrl')]"
            },
            {
              "name": "postgres-admin-url",
              "value": "[parameters('postgresAdminUrl')]"
            },
            {
              "name": "eventhubs-connection-string",
              "value": "[parameters('eventHubsConnectionString')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "stream-processor",
              "image": "[parameters('processorImage')]",
              "env": [
                {
                  "name": "PROCESSOR_LISTEN_ADDR",
                  "value": ":8082"
                },
                {
                  "name": "POSTGRES_URL",
                  "secretRef": "postgres-app-url"
                },
                {
                  "name": "POSTGRES_ADMIN_URL",
                  "secretRef": "postgres-admin-url"
                },
                {
                  "name": "KAFKA_BROKERS",
                  "value": "[format('{0}:9093', parameters('eventHubsHost'))]"
                },
                {
                  "name": "KAFKA_TOPIC",
                  "value": "[parameters('kafkaTopic')]"
                },
                {
                  "name": "KAFKA_DLQ_TOPIC",
                  "value": "[parameters('kafkaDlqTopic')]"
                },
                {
                  "name": "KAFKA_GROUP_ID",
                  "value": "[parameters('kafkaGroupId')]"
                },
                {
                  "name": "KAFKA_SECURITY_PROTOCOL",
                  "value": "SASL_SSL"
                },
                {
                  "name": "KAFKA_SASL_MECHANISM",
                  "value": "PLAIN"
                },
                {
                  "name": "KAFKA_SASL_USERNAME",
                  "value": "$ConnectionString"
                },
                {
                  "name": "KAFKA_SASL_PASSWORD",
                  "secretRef": "eventhubs-connection-string"
                },
                {
                  "name": "KAFKA_TLS_SERVER_NAME",
                  "value": "[parameters('eventHubsHost')]"
                },
                {
                  "name": "KAFKA_ALLOW_AUTO_TOPIC_CREATION",
                  "value": "false"
                }
              ],
              "resources": {
                "cpu": "[json(parameters('processorCpu'))]",
                "memory": "[parameters('processorMemory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('processorMinReplicas')]",
            "maxReplicas": "[parameters('processorMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
      ]
    }
  ],
  "outputs": {
    "ingestUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('ingestAppName')), '2024-03-01').latestRevisionFqdn)]"
    },
    "queryUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('queryAppName')), '2024-03-01').latestRevisionFqdn)]"
    },
    "containerAppsEnvironmentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
    },
    "ingestPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('ingestAppName')), '2024-03-01', 'full').identity.principalId]"
    }
  }
}