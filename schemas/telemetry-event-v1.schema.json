{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulsestream.dev/schemas/telemetry-event-v1.schema.json",
  "title": "PulseStream Telemetry Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "tenant_id",
    "source_id",
    "event_type",
    "timestamp",
    "value",
    "status",
    "region",
    "sequence"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "const": "telemetry"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "value": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warn", "error"]
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    }
  }
}
